{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-ninja",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "FETCHCONTENT_BASE_DIR": "${sourceDir}/.cmake_deps"
      }
    },
    {
      "name": "base-win-ninja",
      "hidden": true,
      "inherits": "base-ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/.vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "client-debug",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TEMPOLINK_BUILD_CLIENT": "ON"
      }
    },
    {
      "name": "juce-client-debug",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TEMPOLINK_BUILD_CLIENT": "OFF",
        "TEMPOLINK_BUILD_JUCE_CLIENT": "ON",
        "TEMPOLINK_FETCH_JUCE": "ON"
      }
    },
    {
      "name": "juce-client-release",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TEMPOLINK_BUILD_CLIENT": "OFF",
        "TEMPOLINK_BUILD_JUCE_CLIENT": "ON",
        "TEMPOLINK_FETCH_JUCE": "ON"
      }
    },
    {
      "name": "juce-client-debug-win",
      "inherits": ["base-win-ninja", "juce-client-debug"],
      "binaryDir": "${sourceDir}/out/build/juce-client-debug"
    },
    {
      "name": "juce-client-release-win",
      "inherits": ["base-win-ninja", "juce-client-release"],
      "binaryDir": "${sourceDir}/out/build/juce-client-release"
    }
  ],
  "buildPresets": [
    {
      "name": "client-debug",
      "configurePreset": "client-debug",
      "jobs": 0
    },
    {
      "name": "juce-client-debug",
      "configurePreset": "juce-client-debug",
      "jobs": 0
    },
    {
      "name": "juce-client-release",
      "configurePreset": "juce-client-release",
      "jobs": 0
    },
    {
      "name": "juce-client-debug-win",
      "configurePreset": "juce-client-debug-win",
      "jobs": 0
    },
    {
      "name": "juce-client-release-win",
      "configurePreset": "juce-client-release-win",
      "jobs": 0
    }
  ]
}
